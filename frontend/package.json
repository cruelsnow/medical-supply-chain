    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.10",
    "echarts": "^5.4.3",
    "element-plus": "^2.4.4",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "vue": "^3.3.11",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/crypto-js": "^4.2.1",
    "@types/node": "^20.10.4",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vitest/coverage-v8": "^1.2.0",
    "@vue/test-utils": "^2.4.4",
    "@vue/tsconfig": "^0.5.1",
    "happy-dom": "^13.3.8",
    "jsdom": "^23.2.0",
    "sass": "^1.69.5",
    "typescript": "^5.3.3",
