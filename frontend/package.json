{
  "name": "medical-supply-chain-frontend",
  "version": "1.0.0",
  "description": "基于区块链的医用耗材供应链管理系统 - 前端应用",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
